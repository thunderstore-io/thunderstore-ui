{
  "name": "@thunderstore/ui",
  "repository": "https://github.com/thunderstore-io/thunderstore-ui",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "preconstruct dev && manypkg check",
    "dev": "node tools/scripts/dev.mjs",
    "build": "preconstruct build && pnpm --filter @thunderstore/cyberstorm-theme run build && pnpm --filter @thunderstore/cyberstorm run build && pnpm --filter @thunderstore/ts-uploader run build",
    "plop": "plop",
    "validate:exports": "node tools/scripts/validate_package_exports.mjs",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage",
    "tsc": "tsc -b",
    "test:container": "node tools/scripts/run_test_container.mjs test",
    "coverage:container": "node tools/scripts/run_test_container.mjs coverage"
  },
  "engines": {
    "node": "24.14.0"
  },
  "dependencies": {
    "@babel/core": "7.25.2",
    "@babel/plugin-transform-runtime": "7.28.5",
    "@babel/preset-env": "7.28.6",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/eslintrc": "2.1.4",
    "@eslint/js": "9.39.2",
    "@manypkg/cli": "0.21.4",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@preconstruct/cli": "2.8.12",
    "@trivago/prettier-plugin-sort-imports": "6.0.0",
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "@vitest/coverage-v8": "3.2.6",
    "chromatic": "13.3.5",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "globals": "16.5.0",
    "plop": "4.0.4",
    "prettier": "3.1.0",
    "stylelint": "16.26.1",
    "stylelint-config-rational-order": "0.1.2",
    "stylelint-config-standard": "36.0.1",
    "stylelint-order": "6.0.4",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "5.2.0",
    "vitest": "3.2.6",
    "webpack": "5.104.1"
  },
  "preconstruct": {
    "packages": [
      "packages/!(cyberstorm|ts-uploader|cyberstorm-theme)"
    ]
  },
  "packageManager": "pnpm@11.5.3"
}
