{
  "name": "@thunderstore/ts-uploader-react",
  "version": "0.1.0",
  "description": "Provides react components for handling file uploads to Thunderstore",
  "repository": "https://github.com/thunderstore-io/thunderstore-ui/tree/master/packages/ts-uploader-react",
  "main": "dist/thunderstore-ts-uploader-react.cjs.js",
  "module": "dist/thunderstore-ts-uploader-react.esm.js",
  "types": "dist/thunderstore-ts-uploader-react.cjs.d.ts",
  "exports": {
    ".": {
      "module": "./dist/thunderstore-ts-uploader-react.esm.js",
      "default": "./dist/thunderstore-ts-uploader-react.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": "24.16.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "@thunderstore/ts-uploader": "workspace:*",
    "@types/react": "19.2.8",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "5.2.0"
  }
