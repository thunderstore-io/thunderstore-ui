{
  "name": "@thunderstore/graph-system",
  "version": "0.1.0",
  "description": "Handles file uploads to Thunderstore",
  "repository": "https://github.com/thunderstore-io/thunderstore-ui/tree/master/packages/graph-system",
  "main": "dist/thunderstore-graph-system.cjs.js",
  "module": "dist/thunderstore-graph-system.esm.js",
  "types": "dist/thunderstore-graph-system.cjs.d.ts",
  "exports": {
    ".": {
      "module": "./dist/thunderstore-graph-system.esm.js",
      "default": "./dist/thunderstore-graph-system.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": "24.16.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "@thunderstore/thunderstore-api": "workspace:*",
    "@thunderstore/typed-event-emitter": "workspace:*",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@vitest/browser": "3.2.6",
    "@vitest/coverage-v8": "3.2.6",
    "playwright": "1.60.0",
    "vitest": "3.2.6"
  }
}
