{
  "name": "@thunderstore/ts-uploader",
  "version": "0.1.0",
  "description": "Handles file uploads to Thunderstore",
  "repository": "https://github.com/thunderstore-io/thunderstore-ui/tree/master/packages/ts-uploader",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "main": "dist/thunderstore-ts-uploader.umd.cjs",
    "module": "dist/thunderstore-ts-uploader.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/thunderstore-ts-uploader.js"
      },
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": "24.16.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "@thunderstore/graph-system": "workspace:*",
    "@thunderstore/thunderstore-api": "workspace:*",
    "@thunderstore/typed-event-emitter": "workspace:*",
    "crypto-js": "4.2.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/crypto-js": "4.2.2",
    "@types/node": "24.12.0",
    "@vitest/browser": "3.2.6",
    "@vitest/coverage-v8": "3.2.6",
    "playwright": "1.60.0",
    "vite": "7.3.5",
    "vite-plugin-dts": "4.5.4",
    "vitest": "3.2.6"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  }
}
