{
  "name": "@thunderstore/dapper-ts",
  "version": "0.1.0",
  "description": "Implementation of Dapper using Thunderstore API as the data source",
  "repository": "https://github.com/thunderstore-io/thunderstore-ui/tree/master/packages/dapper-ts",
  "type": "module",
  "main": "dist/thunderstore-dapper-ts.cjs.js",
  "module": "dist/thunderstore-dapper-ts.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "module": "./dist/thunderstore-dapper-ts.esm.js",
      "default": "./dist/thunderstore-dapper-ts.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "watch": "vitest watch"
  },
  "engines": {
    "node": "24.14.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "@thunderstore/dapper": "workspace:*",
    "@thunderstore/thunderstore-api": "workspace:*",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@vitest/browser": "3.2.6",
    "playwright": "1.55.1",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vitest": "3.2.6"
  }
}
